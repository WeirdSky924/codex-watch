# Legacy system-wide unit retained for existing installations.
# New installations should use systemd/codex-watch-guardian@.service.
[Unit]
Description=Codex Watch Guardian (%i)
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/codex-watch-guardian --session %i
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
